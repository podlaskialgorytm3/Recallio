generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  firstName    String?
  lastName     String?
  passwordHash String
  geminiApiKey String?
  geminiModel      String            @default("gemini-2.5-flash")
  globalKeyCost    Float             @default(0)
  ownKeyCost       Float             @default(0)
  stripeCustomerId String?           @unique
  role             Role              @default(USER)
  createdAt     DateTime      @default(now())
  questionSets     QuestionSet[]
  sessions         Session[]
  userSubscription UserSubscription?
  purchases        PurchaseHistory[]
}

enum Role {
  USER
  ADMIN
}

model QuestionSet {
  id        String     @id @default(cuid())
  userId    String
  name      String
  isPublic  Boolean    @default(false)
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions Question[]
  sessions  Session[]

  @@index([userId])
}

model Question {
  id            String        @id @default(cuid())
  questionSetId String
  externalId    Int
  question      String
  answer        String        @db.Text
  questionSet   QuestionSet   @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  roundAnswers  RoundAnswer[]

  @@index([questionSetId])
}

model Session {
  id            String      @id @default(cuid())
  userId        String
  questionSetId String
  mode          String      @default("sequential") // "random" | "sequential"
  threshold     Int         @default(70)
  status        String      @default("active") // "active" | "finished"
  createdAt     DateTime    @default(now())
  completedAt   DateTime?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  rounds        Round[]

  @@index([userId])
  @@index([questionSetId])
}

model Round {
  id           String        @id @default(cuid())
  sessionId    String
  roundNumber  Int
  averageScore Float?
  createdAt    DateTime      @default(now())
  completedAt  DateTime?
  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers      RoundAnswer[]

  @@index([sessionId])
}

model RoundAnswer {
  id         String   @id @default(cuid())
  roundId    String
  questionId String
  userAnswer String   @db.Text
  score      Int?     // 0-100
  feedback   String?  @db.Text
  answeredAt DateTime @default(now())
  round      Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([questionId])
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?  @db.Text
  checkLimit      Int
  generateLimit   Int
  price           Float
  resetType       String   @default("ONETIME") // "ONETIME" | "CYCLIC"
  resetPeriodDays Int?
  validDays       Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  users           UserSubscription[]
  purchases       PurchaseHistory[]
}

model UserSubscription {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planId             String?
  plan               SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  
  checkedRemaining   Int      @default(10)
  generatedRemaining Int      @default(10)
  
  nextResetAt        DateTime?
  expiresAt          DateTime?
  
  updatedAt          DateTime @updatedAt
}

model PurchaseHistory {
  id              String   @id @default(cuid())
  userId          String
  planId          String
  price           Float
  stripeSessionId String?  @unique
  purchasedAt     DateTime @default(now())
  
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan @relation(fields: [planId], references: [id])
  
  @@index([userId])
  @@index([planId])
}
